# Copie este arquivo para .env e preencha com suas chaves
# cp .env.example .env

# ── Obrigatórias ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
YOUTUBE_API_KEY=AIza...

# ── Clima e previsão (openweathermap.org — gratuito) ─────────────────────────
OPENWEATHER_API_KEY=

# ── Música Jamendo (developer.jamendo.com — gratuito) ────────────────────────
JAMENDO_CLIENT_ID=

# ── Futebol (football-data.org — gratuito) ───────────────────────────────────
FOOTBALL_DATA_API_KEY=

# ── Filmes (themoviedb.org — gratuito) ────────────────────────────────────────
TMDB_API_KEY=

# ── Bíblia (abibliadigital.com.br — gratuito) ────────────────────────────────
ABIBLIADIGITAL_TOKEN=

# ── TTS Providers alternativos (opcional — padrão é edge_tts, sem chave) ─────
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
