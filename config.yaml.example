sources:

  - id: youtube
    type: youtube
    name: "Vídeos do Youtube"
    enabled: true
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    channels:
      # Jornalismo
      - id: UCaGmdJSSiR7fkh2A-c6emsA
        name: "G1"
      - id: UC-wcdrzucnlKGBjyEUaEWaQ
        name: "Jovem Pan News"
      - id: UCvdwhh_fDyWccR42-rReZLw
        name: "CNN Brasil"
      # Podcasts
      - id: UC4ncvgh5hFr5O83MH7-jRJg
        name: "Flow Podcast"
      - id: UCvmWNQH4c2T3Triih3lftiw
        name: "Inteligência Ltda"
      # Educação e Ciência
      - id: UCzBTlYfHYMwVEru4hmLM8hg
        name: "Manual do Mundo"
      - id: UClu474HMt895mVxZdlIHXEA
        name: "Nerdologia"
    settings:
      max_videos_per_channel: 2
      max_videos_total: 15
      days_lookback: 7
      language_preference: [pt, en]
      subscriptions_ratio: 0.6

  - id: noticias
    type: rss
    name: "Notícias do Dia"
    enabled: true
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    feeds:
      - url: "https://g1.globo.com/rss/g1/"
        name: "G1"
      - url: "https://feeds.folha.uol.com.br/emcimadahora/rss091.xml"
        name: "Folha"
      - url: "https://agenciabrasil.ebc.com.br/rss/ultimasnoticias/feed.xml"
        name: "Agência Brasil"
      - url: "https://admin.cnnbrasil.com.br/rss"
        name: "CNN Brasil"
    settings:
      max_items_per_feed: 1
      max_items_total: 7
      days_lookback: 1

  - id: noticias-locais
    type: rss
    name: "Notícias Locais"
    enabled: true
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    # Configure aqui os feeds RSS do seu portal local.
    # Use https://news.google.com/rss/search?q=sua+cidade para busca por cidade.
    feeds:
      - url: "https://news.google.com/rss/search?q=sua+cidade&hl=pt-BR&gl=BR&ceid=BR:pt-419"
        name: "Google — Sua Cidade"
    settings:
      max_items_per_feed: 2
      max_items_total: 10
      days_lookback: 1

  - id: horoscopo
    type: horoscopo
    name: "Horóscopo do Dia"
    enabled: true
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    settings:
      # pair_index: 0   # 0=Áries+Touro, 1=Gêmeos+Câncer, 2=Leão+Virgem,
                        # 3=Libra+Escorpião, 4=Sagitário+Capricórnio, 5=Aquário+Peixes
                        # omitir = rotação automática por dia do ano

  - id: loteria
    type: utility
    name: "Resultados da Loteria"
    enabled: true
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    settings:
      weather:
        enabled: false
      finance:
        enabled: false
      lottery:
        enabled: true
        games:
          - megasena
          - lotofacil
          - quina

  - id: tecnologia
    type: rss
    name: "Tecnologia"
    enabled: true
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    feeds:
      - url: "https://rss.tecmundo.com.br/feed"
        name: "TecMundo"
      - url: "https://olhardigital.com.br/feed/"
        name: "Olhar Digital"
      - url: "https://canaltech.com.br/rss/"
        name: "Canaltech"
    settings:
      max_items_per_feed: 3
      max_items_total: 8
      days_lookback: 1

  - id: reddit
    type: reddit
    name: "Tendências do Reddit"
    enabled: true
    subreddits:
      - programacao
      - brasil
      - investimentos
    settings:
      max_per_subreddit: 3
      max_total: 10
      timeframe: day     # hour | day | week | month | year
      min_score: 50

  - id: quiz
    type: trivia
    name: "Quiz do Dia"
    enabled: true
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    settings:
      amount: 5
      # category: 22   # 9=Geral, 17=Ciência, 18=Tech, 21=Esportes, 22=Geografia, 23=História, 25=Arte
      # difficulty: medium  # easy | medium | hard  (omitir = aleatório)

  - id: efemerides
    type: efemerides
    name: "Hoje na História"
    enabled: true
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    settings:
      max_events: 3
      categories:
        - selected   # eventos curados pela Wikipedia (melhor qualidade)
        - events     # demais eventos do dia

  - id: utilidades
    type: utility
    name: "Resumo do Dia"
    enabled: true
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    settings:
      weather:
        enabled: true
        cities:
          - "Sao Paulo,BR"   # substitua pela sua cidade
        api_key_env: "OPENWEATHER_API_KEY"
        forecast_days: 3
      finance:
        enabled: true
        pairs:
          - "USD-BRL"
          - "EUR-BRL"
          - "BTC-USD"
      ibovespa:
        enabled: true
        top_movers: 3
      sun:
        enabled: true
        lat: -23.5505      # latitude da sua cidade
        lng: -46.6333      # longitude da sua cidade
        tzid: "America/Sao_Paulo"

  - id: musica
    type: music
    name: "Seleção Musical"
    enabled: false
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    settings:
      num_tracks: 3
      source: "jamendo"       # "jamendo" ou "local"
      jamendo:
        api_key_env: "JAMENDO_CLIENT_ID"
        tags: "lounge"        # lounge, jazz, ambient, pop, electronic, classical, rock
        min_duration: 60
        max_duration: 360
      intro_text: "É hora da nossa seleção musical!"
      outro_text: "Voltamos logo com mais programação."

  - id: musica-local
    type: music
    name: "Playlist Local"
    model: "claude-haiku-4-5-20251001"   # estrutura rígida — Haiku suficiente
    enabled: false
    settings:
      num_tracks: 2
      source: "local"
      paths:
        - "/path/para/suas/musicas"   # substitua pelo caminho real

  # ── Plugin: Clipping de Mídia ────────────────────────────────────────────────
  # Gerado manualmente via CLI — o tópico é sempre passado como parâmetro:
  #   python main.py "clipping:queda de avião da empresa xyz"
  # - id: clipping
  #   type: clipping
  #   name: "Clipping"
  #   enabled: true
  #   settings:
  #     max_sources: 5          # máximo de veículos a incluir
  #     days_lookback: 1        # só artigos dos últimos N dias
  #     fetch_content: true     # extrai texto completo via trafilatura
  #     max_content_chars: 2000 # limite de caracteres por artigo
  #     agregadores:            # ordem não implica prioridade — seleção é balanceada (round-robin)
  #       - google_news         # padrão — sem chave de API
  #       - bing_news           # padrão — sem chave de API

  # ── Plugin: Clipping Automático ──────────────────────────────────────────────
  # Descobre automaticamente o assunto mais discutido do dia consultando RSS de
  # grandes portais brasileiros e usando o LLM para identificar o tópico.
  # Ativar: python main.py clipping-auto
  #
  # Novos settings:
  #   categoria           — filtra o LLM para um tema (política, economia, esportes…)
  #   topic_cooldown_hours — evita repetir o mesmo assunto dentro de N horas (isolamento intra-dia)
  #   topic_history_days  — evita repetir assuntos cobertos nos últimos N dias
  #   followup automático — se o assunto já foi coberto hoje, ativa modo de acompanhamento
  #
  # - id: clipping-geral
  #   type: clipping_auto
  #   name: "Clipping Geral"
  #   enabled: false
  #   settings:
  #     max_topics: 3
  #     max_sources: 5
  #     days_lookback: 1
  #     fetch_content: true
  #     max_content_chars: 2000
  #     llm_model: claude-haiku-4-5-20251001
  #     topic_history_days: 7
  #     topic_cooldown_hours: 4
  #     agregadores:
  #       - google_news
  #       - bing_news
  #
  # - id: clipping-economia
  #   type: clipping_auto
  #   name: "Clipping Economia"
  #   enabled: false
  #   settings:
  #     categoria: economia
  #     max_topics: 3
  #     max_sources: 5
  #     topic_history_days: 7
  #     topic_cooldown_hours: 4
  #
  # - id: clipping-esportes
  #   type: clipping_auto
  #   name: "Clipping Esportes"
  #   enabled: false
  #   settings:
  #     categoria: esportes
  #     max_topics: 3
  #     max_sources: 5
  #     topic_history_days: 3
  #     topic_cooldown_hours: 4

  # ── Plugin: Concursos Públicos ───────────────────────────────────────────────
  # - id: concursos
  #   type: concursos_pci
  #   name: "Concursos Públicos"
  #   enabled: true
  #   settings:
  #     max_items: 2
  #     days_lookback: 2

  # ── Plugin: Passagens Bíblicas ───────────────────────────────────────────────
  # Token gratuito em: https://www.abibliadigital.com.br/pt
  # Adicione no .env:  ABIBLIADIGITAL_TOKEN=seu_jwt_aqui
  # - id: biblia
  #   type: biblia
  #   name: "Palavra do Dia"
  #   enabled: true
  #   model: "claude-haiku-4-5-20251001"
  #   settings:
  #     token_env: ABIBLIADIGITAL_TOKEN
  #     version: nvi                      # nvi | acf | ra | kjv | bbe | apee | rvr
  #     mode: random                      # random | book | passage
  #     max_items: 3

  # ── Plugin: Copa do Mundo 2026 ───────────────────────────────────────────────
  # Resultados e agenda com: dia, dia da semana, horário BRT, estádio, cidade,
  # fase, grupo e placar. Fonte: football-data.org (requer FOOTBALL_DATA_API_KEY)
  # - id: copa
  #   type: copa_mundo
  #   name: "Copa do Mundo 2026"
  #   enabled: true
  #   model: claude-haiku-4-5-20251001
  #   settings:
  #     api_key_env: FOOTBALL_DATA_API_KEY
  #     days_lookback: 2   # dias passados de resultados incluídos
  #     days_ahead: 1      # dias à frente de agenda incluídos

  # ── Plugin: Futebol (utility) ────────────────────────────────────────────────
  # - id: brasileirao
  #   type: utility
  #   name: "Brasileirão"
  #   enabled: true
  #   settings:
  #     weather: {enabled: false}
  #     finance: {enabled: false}
  #     lottery: {enabled: false}
  #     football:
  #       enabled: true
  #       competition: BSA         # BSA=Brasileirão, CL=Champions
  #       api_key_env: FOOTBALL_DATA_API_KEY

  # ── Plugin: Filmes ────────────────────────────────────────────────────────────
  # - id: filmes
  #   type: filmes
  #   name: "Cine Indica"
  #   enabled: true
  #   model: "claude-haiku-4-5-20251001"
  #   settings:
  #     api_key_env: TMDB_API_KEY
  #     mode: trending      # trending | now_playing | upcoming | top_rated
  #     language: pt-BR
  #     region: BR
  #     max_movies: 5

  # ── Plugin: WhatsApp (Exportação Manual) ─────────────────────────────────────
  # Exportar: WhatsApp → Grupo → ⋮ → Mais → Exportar conversa → Sem mídia
  # - id: grupo-trabalho
  #   type: whatsapp
  #   name: "Grupo do Trabalho"
  #   enabled: true
  #   settings:
  #     path: "/caminho/para/exportacao.zip"
  #     days_lookback: 1
  #     max_messages: 150
  #     ignore_media: true

# 1, 2 ou 3 narradores. Remova ou comente entradas para reduzir.
# Vozes pt-BR disponiveis (apenas 3):
#   pt-BR-ThalitaMultilingualNeural (Female)
#   pt-BR-AntonioNeural (Male)
#   pt-BR-FranciscaNeural (Female)
narrators:
  - name: "Ana"
    voice: "pt-BR-ThalitaMultilingualNeural"
    personality: "descontraida, curiosa e bem-humorada — faz perguntas e reage com naturalidade"
  - name: "Carlos"
    voice: "pt-BR-AntonioNeural"
    personality: "analitico e direto — complementa com contexto e opiniao assertiva"
  # Terceiro narrador: descomente para ativar
  # - name: "Julia"
  #   voice: "pt-BR-FranciscaNeural"
  #   personality: "irreverente e critica — traz pontos de vista inesperados e humor"

# ── Spots (propagandas / comunicados) ─────────────────────────────────────────
# Três origens: file (MP3 pronto), tts (texto → voz), llm (tema → LLM → voz)
# Rotação ponderada, sem repetição consecutiva, com cap diário por spot.
#
spots:
#   - id: promo-evento
#     type: file
#     path: "spots/evento.mp3"
#     weight: 2
#     max_per_day: 5
#
#   - id: aviso-reuniao
#     type: tts
#     text: "Atenção: reunião geral às 15h na sala principal."
#     voice: "pt-BR-AntonioNeural"
#
spots_config:
  fallback_every: 2            # injeta spot a cada N músicas no modo fallback (0 = desativa)
  between_episodes_every: 3   # injeta break a cada N transições entre episódios (0 = desativa)

# ── Síntese de voz (TTS) ──────────────────────────────────────────────────────
# Provider padrão: edge_tts (gratuito, sem chave de API)
# Outros providers requerem instalação e chave de API — veja comentários abaixo.
#
# tts:
#   provider: edge_tts   # edge_tts (padrão) | openai | elevenlabs | google
#
#   # ── OpenAI TTS (pip install openai) ──────────────────────────────────────
#   openai:
#     api_key_env: OPENAI_API_KEY
#     model: tts-1-hd          # tts-1 (rápido) | tts-1-hd (maior qualidade)
#     voice_map:
#       pt-BR-AntonioNeural: onyx
#       pt-BR-ThalitaMultilingualNeural: nova
#       pt-BR-FranciscaNeural: shimmer
#
#   # ── ElevenLabs (pip install elevenlabs) ──────────────────────────────────
#   elevenlabs:
#     api_key_env: ELEVENLABS_API_KEY
#     model: eleven_multilingual_v2
#     voice_map:
#       pt-BR-AntonioNeural: <voice_id>
#       pt-BR-ThalitaMultilingualNeural: <voice_id>
#
#   # ── Google Cloud TTS (pip install google-cloud-texttospeech) ─────────────
#   google:
#     credentials_env: GOOGLE_APPLICATION_CREDENTIALS
#     language_code: pt-BR
#     voice_map:
#       pt-BR-AntonioNeural: pt-BR-Studio-B
#       pt-BR-ThalitaMultilingualNeural: pt-BR-Studio-C

# ── Modelo de linguagem (LLM) ─────────────────────────────────────────────────
# Suporta qualquer provedor via LiteLLM. Exemplos:
#
#   Anthropic (padrão) — requer ANTHROPIC_API_KEY no .env
#     model: "claude-sonnet-4-6"
#
#   OpenAI — requer OPENAI_API_KEY no .env
#     model: "gpt-4o"
#
#   Google Gemini — requer GEMINI_API_KEY no .env
#     model: "gemini/gemini-2.0-flash"
#
#   Ollama (local, sem custo de API) — requer Ollama instalado
#     model: "ollama/llama3.2"
#     api_base: "http://localhost:11434"
#
llm:
  model: "claude-sonnet-4-6"
  # api_base: "http://localhost:11434"   # necessário apenas para Ollama

  modelos:
    - id: "claude-haiku-4-5-20251001"
      descricao: "rapido e economico — fontes simples, volume alto"
    - id: "claude-sonnet-4-6"
      descricao: "qualidade padrao — uso geral (padrao do sistema)"
    - id: "claude-opus-4-8"
      descricao: "maxima qualidade — conteudo complexo ou criativo"

vinheta:
  voice: "pt-BR-FranciscaNeural"
  rate: "+20%"
  # abertura, id e encerramento são gerados automaticamente a partir de radio.name.
  # Descomente e edite apenas se quiser um texto personalizado:
  # abertura: "Minha Radio — sua rádio personalizada!"
  # id: "Minha Radio!"
  # encerramento: "Minha Radio — até o próximo episódio!"

# ── Avisos entre músicas (modo fallback) ──────────────────────────────────────
announcements:
  enabled: true      # false = desativa os avisos de grade entre músicas

radio:
  name: "Minha Radio"          # nome da rádio — mude aqui para personalizar toda a programação
  background_music: ""
  background_volume_db: -22

# ── Intro de boas-vindas ───────────────────────────────────────────────────────
# Toca uma vez por dia na primeira abertura do player, antes da programação.
# Use {radio_name} para inserir o nome da rádio e {date} para a data falada.
# Liste várias falas — uma será sorteada a cada geração do áudio.
welcome_intro:
  falas:
    - "Bom dia! Bem-vindo à {radio_name}. {date}. É um prazer ter você conosco!"
  # voice: null  # opcional — usa vinheta.voice por padrão

# ── Downloads ─────────────────────────────────────────────────────────────────
downloads:
  enabled: true
  individual: true
  concatenated: true
  zip: true

# ── Agendamento ───────────────────────────────────────────────────────────────
# Modos:
#   Diário  — omita 'date': roda todo dia no horário indicado
#   Pontual — adicione 'date: YYYY-MM-DD': roda uma única vez nessa data
#   Filtro de dias — adicione 'days: [mon, tue, wed, thu, fri]' para dias específicos
#
# Uso: python scheduler.py
#      python scheduler.py --list   (apenas exibe a grade)
schedule:

  # ── Manhã ────────────────────────────────────────────────────────────────────
  - time: "07:00"
    label: "Bom Dia"
    sources: [utilidades, noticias]

  - time: "07:30"
    slot_id: 1
    label: "Seleção Musical"
    sources: [musica]

  - time: "08:00"
    label: "Notícias Locais"
    sources: [noticias-locais]

  - time: "08:30"
    label: "YouTube"
    sources: [youtube]

  # ── Tarde ────────────────────────────────────────────────────────────────────
  - time: "12:00"
    label: "Meio-dia"
    sources: [noticias]

  - time: "14:00"
    label: "Tecnologia"
    sources: [tecnologia]

  - time: "15:00"
    replay_of: 1
    label: "Seleção Musical (tarde)"

  # ── Noite ────────────────────────────────────────────────────────────────────
  - time: "18:00"
    label: "Tarde"
    sources: [noticias, reddit]

  - time: "20:00"
    label: "Noite"
    sources: [youtube]

  # ── Pontual (exemplo) ─────────────────────────────────────────────────────────
  # - time: "10:00"
  #   date: "2026-01-01"
  #   label: "Especial Ano Novo"
  #   sources: [noticias]

  # ── Só em dias úteis (exemplo) ───────────────────────────────────────────────
  # - time: "09:00"
  #   days: [mon, tue, wed, thu, fri]
  #   label: "Notícias da Semana"
  #   sources: [noticias]
